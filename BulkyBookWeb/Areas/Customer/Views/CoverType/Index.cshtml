@model IEnumerable<CoverType>

<div class="text-center">
    <div class="text-primary">COVER TYPES</div>
    <table class="table table-striped table-bordered">
        <thead>
            <tr><th>ID</th><th>Name</th></tr>
        </thead>
        <tbody>
            @foreach(var ct in Model)
            {
                <tr><td>@ct.Id</td><td>@ct.Name</td></tr>
            }
        </tbody>
    </table>
</div>